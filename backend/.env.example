PORT=4000
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/postgres
PRISMA_DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/postgres?schema=gully

AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_ISSUER_BASE_URL=https://your-tenant.us.auth0.com/
AUTH0_AUDIENCE=https://gully-ka-taste-api
AUTH0_CLIENT_ID=your-auth0-spa-client-id

# Comma-separated allowed origins
CORS_ORIGINS=http://localhost:5173

# Optional Cloudinary upload config for /api/v1/uploads/sign
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_FOLDER=gully-ka-taste